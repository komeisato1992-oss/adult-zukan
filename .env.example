# Copy to .env.local and fill in real values.
# All DOUJIN_* write/sync flags default to OFF unless set to exactly "true".

# FANZA TV（月額見放題）登録用アフィリエイトURL（全作品共通・CIDなし）。
# al.fanza.co.jp / al.dmm.co.jp + af_id=zukanjp-001。content= 付き・直リンクは不可。未設定時はボタン非表示。
# NEXT_PUBLIC_FANZA_TV_AFFILIATE_URL=https://al.fanza.co.jp/?lurl=https%3A%2F%2Fpremium.dmm.co.jp%2Fnotice%2Ffanzatv_plus_welcome%2F&af_id=zukanjp-001&ch=link_tool&ch_id=link

# --- Doujin local JSON write / sync ---

# ローカルJSON書き込みを明示的に許可（未設定・false は禁止）
DOUJIN_LOCAL_WRITE_ENABLED=false

# 価格・割引・評価・ランキングのみを更新（未設定・false は無効）
DOUJIN_LIGHT_SYNC_ENABLED=false

# 全商品情報を更新。高負荷のため通常はfalse（未設定・false は無効）
DOUJIN_FULL_SYNC_ENABLED=false

DOUJIN_LIGHT_SYNC_BATCH_SIZE=500
DOUJIN_FULL_SYNC_BATCH_SIZE=100

# 計測ログ（通常はfalse。計測時のみ true）
PERFORMANCE_DEBUG=false

# 同人図鑑「初めて利用する方はこちら」購入ガイド（未設定・false は非表示。アダルト図鑑には影響しない）
ENABLE_FIRST_TIME_GUIDE=false

# --- GitHub (admin import / catalog promote) ---
# サーバーのみ。ブラウザへ渡さないこと。
# GITHUB_TOKEN=ghp_xxxxxxxx  # contents:read/write
# GITHUB_OWNER=your-github-owner
# GITHUB_REPO=adult-zukan
# ADULT_CATALOG_WORKING_BRANCH=catalog-staging
# ADULT_CATALOG_PRODUCTION_BRANCH=main
# main 更新で Vercel Production が自動デプロイされる場合は Deploy Hook 不要
# VERCEL_DEPLOY_VIA_HOOK=1 のときだけ VERCEL_PRODUCTION_DEPLOY_HOOK_URL を呼ぶ
# VERCEL_PRODUCTION_DEPLOY_HOOK_URL=
# VERCEL_DEPLOY_VIA_HOOK=0

# --- Adult catalog write / sync ---

# ローカル data/dmm への直接書き込み（未設定・false は禁止。GitHub正規保存は別）
ADULT_LOCAL_WRITE_ENABLED=false

# 価格・セール・評価・順位のみ更新（未設定・false は手動実行で無効）
ADULT_LIGHT_SYNC_ENABLED=false

# 全商品情報更新。高負荷のため通常はfalse
ADULT_FULL_SYNC_ENABLED=false

ADULT_LIGHT_SYNC_BATCH_SIZE=500
ADULT_FULL_SYNC_BATCH_SIZE=100

# 軽量同期の対象件数上限（第1段階検証は 100。未設定・0 は全件）
# ADULT_LIGHT_SYNC_TARGET_LIMIT=100

# --- Supabase（アダルト図鑑専用プロジェクト） ---
# 競馬用プロジェクトは使わない。専用プロジェクトの Project Settings → API から取得。
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...                    # anon public（または sb_publishable_...）
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # ブラウザ公開用（同上）
# SUPABASE_SERVICE_ROLE_KEY=eyJ...            # service_role secret（サーバーのみ・Git禁止）
#
# 設定箇所:
#   - ローカル: .env.local
#   - 本番: Vercel → Project → Settings → Environment Variables
# SQL: supabase/SETUP.md と supabase/bootstrap.sql を参照

# --- Work live status (price/sale/rating/rank) ---
# WORK_LIVE_STATUS_BACKEND=auto      # auto | supabase | local | off
# WORK_LIVE_STATUS_ENABLED=true
# WORK_LIVE_STATUS_REVALIDATE_SEC=600

# --- Works master (fixed metadata) ---
# WORKS_MASTER_BACKEND=auto のとき、接続設定があれば必ず Supabase。ローカルJSONは障害時のみ。
# WORKS_MASTER_BACKEND=auto          # auto | supabase | local | off
# WORKS_MASTER_ENABLED=true
# WORKS_MASTER_REVALIDATE_SEC=600
# Migration: 001_work_live_status → 002_works（または bootstrap.sql）

# 一時フラグ（移行完了後に削除可）
# ADULT_COMPACT_CATALOG_ENABLED=true
# ADULT_CATALOG_CACHE_ENABLED=true
# ADULT_MEDIA_SHARD_ENABLED=true
